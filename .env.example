# --- Site ---
NEXT_PUBLIC_SITE_URL=https://spotlesscarwash.com

# --- Stripe ---
# Server-side secret key (sk_test_... in test mode, sk_live_... in production)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from `stripe listen` (whsec_...) or the dashboard endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — one per SKU. Defaults baked into app/api/checkout/route.ts
# point at the spotless-carwash *sandbox* account's prices; override here only
# when cutting over to the live account.
# 4-pack list prices: $8/$9/$10/$12 wash · 4-pack ($32/$36/$40/$48 total).
# These are the "regular" list prices; the STRIPE_COUPON_PACK_DISCOUNT below is
# auto-applied to every pack checkout to take $5 off (so customers pay $27/$31/$35/$43).
STRIPE_PRICE_PACK_8=price_1TYbXTGhjWB5e4mpkuHG1Ckd
STRIPE_PRICE_PACK_9=price_1TYbXcGhjWB5e4mpodKcrTAG
STRIPE_PRICE_PACK_10=price_1TYbXkGhjWB5e4mpZnBQM9PI
STRIPE_PRICE_PACK_12=price_1TYbXwGhjWB5e4mpjvVl1Oqf
# Single-token prices: $8/$9/$10/$12 wash · single token.
STRIPE_PRICE_SINGLE_8=price_1TYEItGhjWB5e4mpWsLAcRMJ
STRIPE_PRICE_SINGLE_9=price_1TYEJ3GhjWB5e4mpfgqpzfql
STRIPE_PRICE_SINGLE_10=price_1TYEJBGhjWB5e4mpEIEfFyrT
STRIPE_PRICE_SINGLE_12=price_1TYEJKGhjWB5e4mpdpMew8qJ

# Always-on $5-off 4-pack discount — auto-applied to every pack-mode checkout.
# Singles do not receive it.
STRIPE_COUPON_PACK_DISCOUNT=thoUh0Kr

# Father's Day 2026 sale — $10 off 4-packs (the always-on $5 + an extra $5).
# Auto-replaces STRIPE_COUPON_PACK_DISCOUNT for pack checkouts through
# 2026-06-21 23:59:59 America/Chicago.
STRIPE_COUPON_FATHERS_DAY_2026=sGKM8l9M

# --- Sanity (existing) ---
SANITY_WEBHOOK_SECRET=
