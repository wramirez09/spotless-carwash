#!/usr/bin/env sh

# Pre-push: run e2e tests + production build, but ONLY when pushing to
# `main` or `dev` on the remote. Pushes to feature branches are skipped so
# day-to-day iteration stays fast. Merges into main/dev still trigger checks
# because the push that lands them targets refs/heads/main or refs/heads/dev.
#
# Git passes one line per ref being pushed on stdin:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>

protected_branch_pushed=0

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/dev)
      protected_branch_pushed=1
      ;;
  esac
done

if [ "$protected_branch_pushed" -eq 0 ]; then
  echo "→ Push does not target main or dev — skipping e2e + build checks."
  exit 0
fi

echo "→ Push targets main or dev. Running Playwright e2e tests..."
if ! yarn test:e2e; then
  echo ""
  echo "✖ E2E tests failed. Push aborted."
  echo "  Fix the failing specs (or pass --no-verify to skip, not recommended)."
  exit 1
fi

echo ""
echo "→ Running production build (next build)..."
if ! yarn build; then
  echo ""
  echo "✖ Build failed. Push aborted."
  echo ""
  echo "  Ask Claude to fix the build errors above, e.g.:"
  echo "    \"the pre-push build failed — fix the errors and re-push\""
  echo ""
  exit 1
fi

echo ""
echo "✓ Tests passed and build succeeded — proceeding with push."
