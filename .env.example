# --- Site ---
NEXT_PUBLIC_SITE_URL=

# ---------------------------------------------------------------------------
# Stripe — DEV_* (sandbox) and PROD_* (live). lib/stripeEnv.ts picks DEV_*
# when VERCEL_ENV !== 'production' (local dev + Vercel Preview/Development),
# PROD_* on Vercel Production. On Vercel, set DEV_STRIPE_* in Preview +
# Development envs and PROD_STRIPE_* in Production.
# ---------------------------------------------------------------------------
DEV_STRIPE_SECRET_KEY=
DEV_STRIPE_WEBHOOK_SECRET=
PROD_STRIPE_SECRET_KEY=
PROD_STRIPE_WEBHOOK_SECRET=

# 4-pack list prices: $8/$9/$10/$12 wash · 4-pack ($32/$36/$40/$48 total).
# The pack-discount coupon is auto-applied at checkout for $5 off (so customers
# pay $27/$31/$35/$43). During the Father's Day sale window, the Father's Day
# coupon stands in for the combined $10 off.
DEV_STRIPE_PRICE_PACK_8=
DEV_STRIPE_PRICE_PACK_9=
DEV_STRIPE_PRICE_PACK_10=
DEV_STRIPE_PRICE_PACK_12=
PROD_STRIPE_PRICE_PACK_8=
PROD_STRIPE_PRICE_PACK_9=
PROD_STRIPE_PRICE_PACK_10=
PROD_STRIPE_PRICE_PACK_12=

# Single-token prices: $8/$9/$10/$12 wash · single token.
DEV_STRIPE_PRICE_SINGLE_8=
DEV_STRIPE_PRICE_SINGLE_9=
DEV_STRIPE_PRICE_SINGLE_10=
DEV_STRIPE_PRICE_SINGLE_12=
PROD_STRIPE_PRICE_SINGLE_8=
PROD_STRIPE_PRICE_SINGLE_9=
PROD_STRIPE_PRICE_SINGLE_10=
PROD_STRIPE_PRICE_SINGLE_12=

# Always-on $5-off 4-pack discount — auto-applied to every pack-mode checkout.
# Singles do not receive it.
DEV_STRIPE_COUPON_PACK_DISCOUNT=
PROD_STRIPE_COUPON_PACK_DISCOUNT=

# Father's Day 2026 sale — $10 off 4-packs. Auto-replaces the pack discount
# for pack checkouts through 2026-06-21 23:59:59 America/Chicago.
DEV_STRIPE_COUPON_FATHERS_DAY_2026=
PROD_STRIPE_COUPON_FATHERS_DAY_2026=

# --- Sanity ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
SANITY_WEBHOOK_SECRET=
SANITY_API_READ_TOKEN=
SANITY_WRITE_TOKEN=
