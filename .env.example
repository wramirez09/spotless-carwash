# --- Site ---
NEXT_PUBLIC_SITE_URL=https://spotlesscarwash.com

# --- Stripe ---
# Server-side secret key (sk_test_... in test mode, sk_live_... in production)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from `stripe listen` (whsec_...) or the dashboard endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — one per token pack. Create three Products + Prices in the
# Stripe Dashboard (5 Tokens / 10 Tokens / 25 Tokens) and paste the price_... IDs.
STRIPE_PRICE_5=price_...
STRIPE_PRICE_10=price_...
STRIPE_PRICE_25=price_...

# --- Sanity (existing) ---
SANITY_WEBHOOK_SECRET=
